# Claude API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=여기에키붙여넣기

# Database — PostgreSQL (Neon / Supabase / Railway 등)
# 예: postgresql://user:password@host/db?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/mydb?sslmode=require"

# 사이트 접근 비밀번호 — 설정 시 모든 페이지/API 에 Basic Auth 적용
# 배포 시 반드시 설정. 비워두면 인증 없이 동작(로컬 개발용).
SITE_PASSWORD=
SITE_USERNAME=admin
